DATABASE_URL=postgresql://postgres:postgres@localhost:5432/padel
PORT=4000

# Secret key for admin API endpoints (required for POST/PUT/DELETE /api/admin/*)
ADMIN_API_KEY=change-me-to-a-random-secret

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# Docker compose defaults (for reference)
POSTGRES_DB=padel
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
